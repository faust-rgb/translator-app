<Window x:Class="TranslatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:TranslatorApp.Converters"
        mc:Ignorable="d"
        Title="AI 文档翻译器"
        Height="760"
        Width="1420"
        MinHeight="680"
        MinWidth="1120"
        Icon="Assets/app-icon.png"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:DocumentStatusToTextConverter x:Key="StatusConverter" />
        <Style x:Key="CompactButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="0,0,8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FFF5F2EA" />
            <Setter Property="BorderBrush" Value="#FFD4C5A2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#FFC97A1A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FFAA6310" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="DangerToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#FFF8E9E5" />
            <Setter Property="Foreground" Value="#FF8C3A22" />
            <Setter Property="BorderBrush" Value="#FFD9A595" />
        </Style>
        <Style x:Key="ToolbarIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CompactSectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionLabelStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Foreground" Value="#FF6C6454" />
        </Style>
        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="206" MinHeight="150" />
            <RowDefinition Height="6" />
            <RowDefinition Height="*" MinHeight="220" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="8" Background="#FFF7F4EC" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.65*" />
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="本地 AI 文档翻译器" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="#FF5F5A4E"
                               TextWrapping="Wrap"
                               Text="支持 DOCX / XLSX / PPTX / PDF / EPUB / MOBI / AZW3。只把文本送给大模型，文档处理在本地完成。电子书会在保留结构后输出为 EPUB 或 DOCX。" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,10,0">
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="接口协议" />
                    <ComboBox Style="{StaticResource CompactComboBoxStyle}" Margin="0,0,0,6" SelectedValue="{Binding ProviderType}" SelectedValuePath="Content">
                        <ComboBoxItem Content="AnthropicCompatible" />
                        <ComboBoxItem Content="OpenAiCompatible" />
                    </ComboBox>
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="访问地址" />
                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0,10,0">
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="模型名称" />
                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,0,6" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="API Key" />
                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="接口测试" />
                    <Button Style="{StaticResource CompactButtonStyle}" Margin="0,0,0,6" Command="{Binding TestConnectionCommand}" Content="连接测试" />
                    <Button Style="{StaticResource CompactButtonStyle}" Margin="0,0,0,6" Command="{Binding LoadConfigFileCommand}" Content="加载配置" />
                    <Button Style="{StaticResource CompactButtonStyle}" Margin="0,0,0,0" Command="{Binding ExportConfigFileCommand}" Content="导出配置" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,8,0,8" Padding="8,6" Background="#FFF8F8F8" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="源语言" />
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource CompactComboBoxStyle}"
                              IsEditable="True"
                              ItemsSource="{Binding CommonLanguages}"
                              Text="{Binding SourceLanguage, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="目标语言" />
                    <ComboBox Grid.Column="4"
                              Style="{StaticResource CompactComboBoxStyle}"
                              IsEditable="True"
                              ItemsSource="{Binding CommonLanguages}"
                              Text="{Binding TargetLanguage, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Column="6" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="输出字体" />
                    <TextBox Grid.Column="7"
                             Style="{StaticResource CompactTextBoxStyle}"
                             Text="{Binding OutputFontFamily, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Column="9" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="输出字号" />
                    <TextBox Grid.Column="10"
                             Style="{StaticResource CompactTextBoxStyle}"
                             Text="{Binding OutputFontSize, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Column="12" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="输出目录" />
                    <TextBox Grid.Column="13"
                             Style="{StaticResource CompactTextBoxStyle}"
                             Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="15"
                            Style="{StaticResource CompactButtonStyle}"
                            Margin="0,0,0,0"
                            Command="{Binding PickOutputDirectoryCommand}"
                            Content="选择目录" />

                    <TextBlock Grid.Column="17" VerticalAlignment="Center" Style="{StaticResource SectionLabelStyle}" Text="电子书输出" />
                    <ComboBox Grid.Column="18"
                              Style="{StaticResource CompactComboBoxStyle}"
                              ItemsSource="{Binding EbookOutputFormats}"
                              Text="{Binding EbookOutputFormat, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Border Grid.Row="1"
                        Padding="10,6"
                        Background="#FFFBF7EF"
                        BorderBrush="#FFE7D8B3"
                        BorderThickness="1"
                        CornerRadius="8">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,6"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="操作" />
                        <WrapPanel>
                            <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Command="{Binding StartCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE768;" />
                                    <TextBlock VerticalAlignment="Center" Text="开始翻译" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding PauseOrResumeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE769;" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding PauseButtonText}" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource DangerToolbarButtonStyle}" Command="{Binding StopCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE71A;" />
                                    <TextBlock VerticalAlignment="Center" Text="停止任务" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding AddFilesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8B7;" />
                                    <TextBlock VerticalAlignment="Center" Text="添加文档" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ClearFilesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE74D;" />
                                    <TextBlock VerticalAlignment="Center" Text="清空列表" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding SaveSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE74E;" />
                                    <TextBlock VerticalAlignment="Center" Text="保存配置" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding OpenOutputDocumentCommand}" CommandParameter="{Binding SelectedDocument}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8A5;" />
                                    <TextBlock VerticalAlignment="Center" Text="打开译后文档" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButtonStyle}" Click="OpenTranslationSettingsButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE713;" />
                                    <TextBlock VerticalAlignment="Center" Text="翻译设置" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="任务列表" />
                    <TextBlock Foreground="#FF666666" Text="右键任务可继续、删除或打开译后文档。" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock FontWeight="SemiBold" Text="{Binding OverallProgress, StringFormat=总进度 {0}%}" />
                    <ProgressBar Width="200" Height="12" Margin="0,4,0,0" Value="{Binding OverallProgress}" Maximum="100" />
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="1"
                      x:Name="TaskGrid"
                      Margin="0,6,0,0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      ItemsSource="{Binding Documents}"
                      SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="TaskGridRow_PreviewMouseRightButtonDown" />
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="继续任务"
                                  Click="ResumeTaskMenuItem_Click" />
                        <MenuItem Header="删除任务"
                                  Click="RemoveTaskMenuItem_Click" />
                        <MenuItem Header="打开译后文档"
                                  Click="OpenOutputDocumentMenuItem_Click" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="2.2*" Header="源文件" Binding="{Binding SourcePath}" />
                    <DataGridTextColumn Width="1.7*" Header="输出文件" Binding="{Binding OutputPath}" />
                    <DataGridTextColumn Width="0.5*" Header="类型" Binding="{Binding FileType}" />
                    <DataGridTextColumn Width="0.6*" Header="状态" Binding="{Binding Status, Converter={StaticResource StatusConverter}}" />
                    <DataGridTextColumn Width="0.55*" Header="进度" Binding="{Binding Progress, StringFormat={}{0}%}" />
                    <DataGridTextColumn Width="1.1*" Header="详情" Binding="{Binding ProgressText}" />
                    <DataGridTextColumn Width="1.0*" Header="错误信息" Binding="{Binding ErrorMessage}" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <GridSplitter Grid.Row="3"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#FFBDBDBD"
                      ShowsPreview="True"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext" />

        <Border Grid.Row="4" Padding="10" Background="#FFF3F3F3" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding StreamPreviewTitle}" />
                <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Text="运行日志" />

                <DockPanel Grid.Column="2">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="任务历史" />
                    <Button DockPanel.Dock="Right" Margin="8,0,0,0" Height="22" Padding="10,1" Command="{Binding ClearHistoryCommand}" Content="清空历史" />
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,6,8,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Visible">
                    <TextBlock FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollContentPresenter}}"
                               Text="{Binding StreamPreviewText}" />
                </ScrollViewer>

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         x:Name="LogTextBox"
                         Margin="8,6,8,0"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         HorizontalScrollBarVisibility="Disabled"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="LogTextBox_TextChanged"
                         Text="{Binding LogText}" />

                <DataGrid Grid.Row="1"
                          Grid.Column="2"
                          Margin="8,6,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          ItemsSource="{Binding HistoryItems}"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="0.9*" Header="时间" Binding="{Binding Timestamp, StringFormat={}{0:MM-dd HH:mm}}" />
                        <DataGridTextColumn Width="1.15*" Header="源文件" Binding="{Binding SourcePath}" />
                        <DataGridTextColumn Width="0.65*" Header="状态" Binding="{Binding Status}" />
                        <DataGridTextColumn Width="0.55*" Header="耗时(s)" Binding="{Binding DurationSeconds}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
