# Auto detect text files and normalize line endings
* text=auto eol=crlf

# Source code
*.cs text eol=crlf
*.xaml text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf

# Config / data
*.json text eol=crlf
*.xml text eol=crlf
*.config text eol=crlf

# Documentation
*.md text eol=crlf
*.txt text eol=crlf

# Binary
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.dll binary
*.exe binary
*.traineddata binary
